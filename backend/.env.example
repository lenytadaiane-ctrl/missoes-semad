# ── Banco de dados ─────────────────────────────────────────────────────────────
# Railway injeta DATABASE_URL automaticamente ao adicionar o plugin PostgreSQL.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@host:5432/railway"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3001

# ── CORS ───────────────────────────────────────────────────────────────────────
# URL do frontend em produção (ex: https://missoes-ieadms.vercel.app)
FRONTEND_URL="https://seu-app.vercel.app"

# ── Upload de arquivos ─────────────────────────────────────────────────────────
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=5242880
